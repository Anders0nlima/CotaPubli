# Supabase (backend precisa da chave SECRETA — nunca da publishable/anon)
# Dashboard → Project Settings → API:
#   - Nova stack: "Secret key" (prefixo sb_secret_...)
#   - Legacy: "service_role" (JWT longo começando com eyJ...)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_OR_legacy_service_role_JWT

# Mercado Pago
MP_PLATFORM_ACCESS_TOKEN=your-mp-access-token
MP_WEBHOOK_SECRET=your-webhook-hmac-secret

# Cloudflare R2
CF_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=cotapubli-media
R2_PUBLIC_DOMAIN=https://media.cotapubli.com.br

# App
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
